[Unit]
Description=Video Maker FastAPI backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pinggu
Group=pinggu
WorkingDirectory=/home/pinggu/personal/video-maker-server
EnvironmentFile=/home/pinggu/personal/video-maker-server/deploy/env.example
ExecStart=/home/pinggu/personal/video-maker-server/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

