[Unit]
Description=Video Maker FastAPI backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pinggu
Group=pinggu
WorkingDirectory=/home/pinggu/video-maker-repo/server
EnvironmentFile=/home/pinggu/video-maker-repo/server/deploy/env.production
ExecStart=/home/pinggu/video-maker-repo/server/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
